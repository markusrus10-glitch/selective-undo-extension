{
  "manifest_version": 3,
  "name": "Selective Undo",
  "version": "1.0.0",
  "description": "Выборочная отмена действий в браузере — выбери что откатить",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ]
}
